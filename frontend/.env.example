# GoodSpot Frontend — Environment Variables
# ─────────────────────────────────────────────────────────────────
# For LOCAL development: create .env.local and add:
#   NEXT_PUBLIC_API_URL=http://localhost:8000
#
# For VERCEL deployment: set this in Vercel → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────

# URL of the FastAPI backend
# Local dev: http://localhost:8000
# Production: https://<your-render-service>.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8000
